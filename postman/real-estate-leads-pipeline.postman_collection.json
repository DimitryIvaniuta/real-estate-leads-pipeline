{
  "info": {
    "name": "Real Estate Leads Pipeline",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8080"},
    {"key": "tenantId", "value": "11111111-1111-1111-1111-111111111111"},
    {"key": "leadId", "value": ""},
    {"key": "bearerToken", "value": "replace-with-jwt"}
  ],
  "item": [
    {
      "name": "Portal - Fetch CSRF Token",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/portal/csrf"
      }
    },
    {
      "name": "Create Lead",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Authorization", "value": "Bearer {{bearerToken}}"},
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenantId\": \"{{tenantId}}\",\n  \"agentId\": \"agent-1\",\n  \"clientName\": \"Alice Buyer\",\n  \"clientEmail\": \"alice@example.com\",\n  \"clientPhone\": \"+48123123123\",\n  \"propertyArea\": \"Gdansk\",\n  \"budgetAmount\": 950000,\n  \"sourceChannel\": \"website\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/leads"
      }
    },
    {
      "name": "Get Lead",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{bearerToken}}"}
        ],
        "url": "{{baseUrl}}/api/v1/leads/{{leadId}}?tenantId={{tenantId}}"
      }
    },
    {
      "name": "List Leads by Tenant",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{bearerToken}}"}
        ],
        "url": "{{baseUrl}}/api/v1/leads?tenantId={{tenantId}}"
      }
    },
    {
      "name": "Pipeline Summary",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{bearerToken}}"}
        ],
        "url": "{{baseUrl}}/api/v1/leads/summary?tenantId={{tenantId}}"
      }
    },
    {
      "name": "Lead Activities",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{bearerToken}}"}
        ],
        "url": "{{baseUrl}}/api/v1/leads/{{leadId}}/activities?tenantId={{tenantId}}"
      }
    },
    {
      "name": "Advance Lead to QUALIFIED",
      "request": {
        "method": "PUT",
        "header": [
          {"key": "Authorization", "value": "Bearer {{bearerToken}}"},
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"targetPhase\": \"QUALIFIED\",\n  \"actor\": \"agent-1\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/leads/{{leadId}}/phase?tenantId={{tenantId}}"
      }
    }
  ]
}
